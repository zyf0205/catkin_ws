<launch>
  <!-- ========== 参数定义 ========== -->
  <arg name="map_size_x_"/>
  <arg name="map_size_y_"/>
  <arg name="map_size_z_"/>
  <arg name="odometry_topic"/>
  <arg name="camera_pose_topic"/>
  <arg name="depth_topic"/>
  <arg name="cloud_topic"/>
  <arg name="cx"/>
  <arg name="cy"/>
  <arg name="fx"/>
  <arg name="fy"/>
  <arg name="max_vel"/>
  <arg name="max_acc"/>
  <arg name="planning_horizon"/>
  <arg name="point_num"/>
  <arg name="point0_x"/>
  <arg name="point0_y"/>
  <arg name="point0_z"/>
  <arg name="flight_type"/>

  <!-- ========== EGO Planner 主节点 ========== -->
  <node pkg="ego_planner" name="ego_planner_node" type="ego_planner_node" output="screen">
    
    <!-- ========== 话题映射 ========== -->
    <remap from="/odom_world" to="$(arg odometry_topic)"/>
    <remap from="/grid_map/odom" to="$(arg odometry_topic)"/>
    <remap from="/grid_map/cloud" to="$(arg cloud_topic)"/>
    <remap from="/grid_map/pose" to="$(arg camera_pose_topic)"/> 
    <remap from="/grid_map/depth" to="$(arg depth_topic)"/>
    <remap from="~waypoints" to="/waypoint_generator/waypoints"/>

    <!-- ========== FSM 参数 ========== -->
    <param name="fsm/flight_type" value="$(arg flight_type)" type="int"/>
    
    <!-- ✅ 【关键修改3】重规划阈值调大，减少频繁重规划 -->
    <param name="fsm/thresh_replan_time" value="1.0" type="double"/>
    <param name="fsm/thresh_no_replan_meter" value="1.0" type="double"/>
    <param name="fsm/planning_horizon" value="$(arg planning_horizon)" type="double"/>
    
    <!-- ✅ 【关键修改4】时间参数优化 -->
    <param name="fsm/planning_horizen_time" value="3.0" type="double"/>
    <param name="fsm/emergency_time_" value="1.0" type="double"/>
    
    <!-- ✅ 初始航点 -->
    <param name="fsm/waypoint_num" value="$(arg point_num)" type="int"/>
    <param name="fsm/waypoint0_x" value="$(arg point0_x)" type="double"/>
    <param name="fsm/waypoint0_y" value="$(arg point0_y)" type="double"/>
    <param name="fsm/waypoint0_z" value="$(arg point0_z)" type="double"/>

    <!-- ========== Grid Map 参数 ========== -->
    
    <!-- ✅ 【关键修改5】分辨率从0.05改为0.1，性能提升8倍 -->
    <param name="grid_map/resolution" value="0.1" /> 
    
    <param name="grid_map/map_size_x" value="$(arg map_size_x_)" /> 
    <param name="grid_map/map_size_y" value="$(arg map_size_y_)" /> 
    <param name="grid_map/map_size_z" value="$(arg map_size_z_)" /> 
    
    <!-- ✅ 【关键修改6】膨胀半径加大，提高安全性 -->
    <param name="grid_map/obstacles_inflation" value="0.45" /> 
    
    <param name="grid_map/ground_height" value="-0.1"/>
    
    <!-- ✅ 【关键修改7】局部更新范围缩小，提高实时性 -->
    <param name="grid_map/local_update_range_x" value="6.0" /> 
    <param name="grid_map/local_update_range_y" value="6.0" /> 
    <param name="grid_map/local_update_range_z" value="4.0" /> 
    
    <!-- ✅ 【关键修改8】射线长度适配LiDAR -->
    <param name="grid_map/min_ray_length" value="0.2"/>
    <param name="grid_map/max_ray_length" value="8.0"/>
    
    <!-- ✅ 相机参数（点云模式下不使用） -->
    <param name="grid_map/cx" value="$(arg cx)"/>
    <param name="grid_map/cy" value="$(arg cy)"/>
    <param name="grid_map/fx" value="$(arg fx)"/>
    <param name="grid_map/fy" value="$(arg fy)"/>
    
    <!-- ✅ 【关键修改9】概率参数调松，避免地图过于保守 -->
    <param name="grid_map/use_depth_filter" value="true"/>
    <param name="grid_map/p_hit" value="0.70"/>
    <param name="grid_map/p_miss" value="0.30"/>
    <param name="grid_map/p_min" value="0.12"/>
    <param name="grid_map/p_max" value="0.90"/>
    <param name="grid_map/p_occ" value="0.80"/>
    
    <!-- ✅ 坐标系设置 -->
    <param name="grid_map/pose_type" value="2"/>  <!-- 2 = Odometry -->
    <param name="grid_map/frame_id" value="camera_init"/>

    <!-- ========== Planner Manager 参数 ========== -->
    <param name="manager/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="manager/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="manager/max_jerk" value="4.0" type="double"/>
    
    <!-- ✅ 【关键修改10】控制点间距加大，轨迹更平滑 -->
    <param name="manager/control_points_distance" value="0.5" type="double"/>
    <param name="manager/feasibility_tolerance" value="0.05" type="double"/>
    <param name="manager/planning_horizon" value="$(arg planning_horizon)" type="double"/>
    
    <!-- ✅ 【关键修改11】添加dynamic参数 -->
    <param name="manager/use_distinctive_trajs" value="false" type="bool"/>

    <!-- ========== Optimization 参数 ========== -->
    
    <!-- ✅ 【关键修改12】权重重新调整，优先安全性 -->
    <param name="optimization/lambda_smooth" value="1.5" type="double"/>        <!-- 平滑性权重 ↑ -->
    <param name="optimization/lambda_collision" value="15.0" type="double"/>    <!-- 碰撞权重 ↑↑ -->
    <param name="optimization/lambda_feasibility" value="1.0" type="double"/>   <!-- 可行性权重 ↑ -->
    <param name="optimization/lambda_fitness" value="2.0" type="double"/>       <!-- 目标吸引 ↑ -->
    
    <!-- ✅ 【关键修改13】安全距离加大 -->
    <param name="optimization/dist0" value="0.8" type="double"/>                <!-- 安全距离阈值 -->
    <param name="optimization/swarm_clearance" value="0.5" type="double"/>
    
    <param name="optimization/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="optimization/max_acc" value="$(arg max_acc)" type="double"/>
    
    <!-- ✅ 【关键修改14】优化迭代参数 -->
    <param name="optimization/algorithm1" value="15" type="int"/>               <!-- LBFGS迭代次数 -->
    <param name="optimization/algorithm2" value="15" type="int"/>               <!-- LBFGS迭代次数 -->
    <param name="optimization/max_iteration_num1" value="2" type="int"/>        <!-- 外层迭代 -->
    <param name="optimization/max_iteration_num2" value="300" type="int"/>      <!-- 内层迭代 -->
    <param name="optimization/max_iteration_num3" value="200" type="int"/>
    <param name="optimization/max_iteration_num4" value="200" type="int"/>
    
    <param name="optimization/order" value="3" type="int"/>

    <!-- ========== B-Spline 参数 ========== -->
    <param name="bspline/limit_vel" value="$(arg max_vel)" type="double"/>
    <param name="bspline/limit_acc" value="$(arg max_acc)" type="double"/>
    <param name="bspline/limit_ratio" value="1.1" type="double"/>

  </node>
</launch>